# TeachNexus Frontend - Environment Variables

# API Configuration
REACT_APP_API_BASE_URL=http://localhost:5000

# Environment
REACT_APP_ENV=development

# Feature Flags (for conditional rendering)
REACT_APP_ENABLE_BETA_FEATURES=false
REACT_APP_DEBUG_MODE=true

# External Services (exposing only safe, public keys for frontend)
# Note: Keep secret keys on backend only. Public keys only here.
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# Analytics (optional)
REACT_APP_ANALYTICS_ID=

# Version
REACT_APP_VERSION=1.0.0
